# ============================================
# TaskForge AI — Root Git Ignore & Security Policy
# ============================================

# ── 1. ENVIRONMENT VARIABLES & SECRETS (CRITICAL) ──
# Explicitly block all environment and secret files from version control
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
*.env
*.env.*
!.env.example

# Private keys, certificates, and credentials
*.pem
*.key
*.cert
*.crt
*.pfx
*.p12
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
secrets.json
credentials.json
service-account*.json
jwt-secret.txt

