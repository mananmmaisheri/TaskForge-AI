# ==============================================================================
# 🔒 TaskForge AI — Secure Environment Configuration Example
# ==============================================================================
# SECURITY NOTICE & PROTECTION POLICY:
# 1. DO NOT commit your real `.env` file to version control. It is explicitly
#    ignored in root, backend, and frontend `.gitignore` and `.dockerignore`.
# 2. To get started locally: copy this file to `.env` (`cp .env.example .env`).
# 3. Never hardcode live API keys, JWT secrets, or production database passwords
#    into source code or commit them to git repositories.
# 4. For Docker deployments, set environment variables via secure docker secrets
#    or pass them at runtime using `docker run --env-file .env`.
# ==============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://taskforge:taskforge_password@localhost:5432/taskforge_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI / Google ADK ---
GOOGLE_API_KEY=your-gemini-api-key-here

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
FRONTEND_URL=http://localhost:3000
